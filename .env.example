# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Groq
GROQ_API_KEY=

# App URL (optional — Redirect-URI wird sonst aus dem Request abgeleitet)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Google Calendar — Redirect-URI in Google Cloud Console (exakt, ohne Slash am Ende):
# http://localhost:3000/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Optional (wenn leer: NEXT_PUBLIC_SITE_URL + /api/auth/google/callback)
GOOGLE_REDIRECT_URI=

# Garmin (garmin-connect npm) — ohne Anführungszeichen in .env.local
# Bei MFA: npm run garmin:login (speichert Tokens in .garmin-tokens/)
GARMIN_EMAIL=
GARMIN_PASSWORD=
# GARMIN_DOMAIN=garmin.com
# GARMIN_TOKEN_PATH=.garmin-tokens

# Strava (optional — ohne Developer-Keys überspringen)
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=

# Vercel Cron
CRON_SECRET=generate-a-random-secret

# Web Push (optional) — npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:you@example.com
